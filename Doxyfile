# Doxyfile for Quasai project

# Project information
PROJECT_NAME           = "Quasai"
PROJECT_BRIEF          = "A lightweight C++ neural network library with autograd support"
PROJECT_LOGO           = "docs/logo.svg"
PROJECT_NUMBER         = "0.1.0"

USE_MDFILE_AS_MAINPAGE = "README.md"
HTML_EXTRA_STYLESHEET = "docs/custom.css"

# Input/output settings
OUTPUT_DIRECTORY       = docs/doxygen
INPUT                  = include/ README.md docs/custom.css
RECURSIVE              = YES
EXCLUDE                = 
EXCLUDE_PATTERNS       = */build/* */.git/* */tests/* */examples/* */benchmarks/*

# File patterns
FILE_PATTERNS          = *.hpp *.cpp *.h *.c

# Documentation extraction
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_PRIV_VIRTUAL  = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = NO
EXTRACT_ANON_NSPACES  = NO
HIDE_UNDOC_MEMBERS    = NO
HIDE_UNDOC_CLASSES    = NO
HIDE_FRIEND_COMPOUNDS = NO
HIDE_IN_BODY_DOCS     = NO
SHOW_INCLUDE_FILES     = YES
SHOW_GROUPED_MEMB_INC  = NO
FORCE_LOCAL_INCLUDES   = NO

# Doxygen processing
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = YES
INHERIT_DOCS            = YES
SEPARATE_MEMBER_PAGES  = NO
TAB_SIZE                = 2
ALIASES                 = 
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 5

# Warnings
WARN_NO_PARAMDOC       = YES
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           = 

# Input filtering
INPUT_FILTER           = 
FILTER_PATTERNS         = 

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION     = YES
VERBATIM_HEADERS        = YES

# Configuration options for C++ specific parts
HIDE_SCOPE_NAMES       = NO
SHOW_USED_FILES        = YES
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES
LAYOUT_FILE            = 
CITE_DOCS              = NO

# Configuration options for the alphabetical class index
ALPHABETICAL_INDEX     = YES
COLS_IN_ALPHA_INDEX    = 5

# Configuration options for the HTML output
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

HTML_COLORSTYLE        = LIGHT

HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80

HTML_FORMULA_FORMAT    = PNG
HTML_TIMESTAMP         = YES
MATHJAX_RELPATH        = https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO
EXTERNAL_SEARCH        = NO

# Configuration options for the LaTeX output
GENERATE_LATEX         = NO
LATEX_OUTPUT           = latex
LATEX_CMD_NAME         = latex
MAKEINDEX_CMD_NAME     = makeindex
LATEX_MAKEINDEX_CMD    = 
COMPACT_LATEX          = NO
PAPER_TYPE             = a4
PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES
LATEX_BATCHMODE        = NO

# Configuration options for the RTF output
GENERATE_RTF           = NO
RTF_OUTPUT             = rtf
COMPACT_RTF             = NO
RTF_HYPERLINKS         = NO

# Configuration options for the man page output
GENERATE_MAN           = NO
MAN_OUTPUT             = man
MAN_EXTENSION          = .3
MAN_LINKS              = NO

# Configuration options for the XML output
GENERATE_XML           = NO
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = YES

# Configuration options for the DOCBOOK output
GENERATE_DOCBOOK       = NO
DOCBOOK_OUTPUT         = docbook

# Configuration options for the AutoGen output
GENERATE_AUTOGEN_DEF  = NO

# Configuration options for the Perl module output
GENERATE_PERLMOD       = NO
PERLMOD_OUTPUT         = perlmod
PERLMOD_LATEX          = NO

# Configuration options for the preprocessor
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = 
INCLUDE_FILES          = 
PREDEFINED             = 
EXPAND_AS_DEFINED      = 
SKIP_FUNCTION_MACROS   = YES

# Configuration options related to the tag file
GENERATE_TAGFILE       = 
ALLEXTERNALS           = NO
EXTERNAL_GROUPS        = YES
EXTERNAL_PAGES         = YES

# Configuration options related to source browsing
USE_HTAGS              = NO
VERBATIM_HEADERS        = YES

# Configuration options related to the dot tool (Graphviz)
CLASS_DIAGRAMS         = YES
HAVE_DOT               = YES
DOT_NUM_THREADS        = 0
DOT_FONTNAME           = Helvetica
DOT_FONTSIZE           = 10
DOT_FONTPATH           = 
CLASS_GRAPH             = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS            = YES
UML_LOOK                = YES
UML_LIMIT_NUM_FIELDS   = 10
TEMPLATE_RELATIONS      = NO
INCLUDE_GRAPH           = YES
INCLUDED_BY_GRAPH       = YES
CALL_GRAPH              = NO
CALLER_GRAPH           = NO
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH         = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG         = YES
DOT_PATH                = 
DOTFILE_DIRS            = 
MSCGEN_PATH             = 
PLANTUML_JAR_PATH      = 
PLANTUML_INCLUDE_PATH  = 
DOT_GRAPH_MAX_NODES    = 50
MAX_DOT_GRAPH_DEPTH    = 0
DOT_TRANSPARENT        = NO
DOT_MULTI_TARGETS      = NO
GENERATE_LEGEND         = YES
DOT_CLEANUP            = YES
